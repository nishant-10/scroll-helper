{
    "manifest_version": 3,
    "name": "Scroll Helper - Smart Scroll Buttons",
    "description": "Floating scroll buttons with support for scrolling to the top, bottom, specific text, and custom percentages with a single click.",
    "version": "1.0.2",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "icons": {
        "16": "icons/16.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    }
}